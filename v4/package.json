{
  "name": "v4-sujeet-pro",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "postinstall": "npx playwright install chromium",
    "dev": "astro dev",
    "build": "astro build && cp dist/sitemap-0.xml dist/sitemap.xml",
    "preview": "astro preview",
    "check": "astro check",
    "lint": "eslint --fix .",
    "format": "prettier . --write --ignore-unknown --loglevel error",
    "test": "vitest run",
    "validate:content": "npx tsx scripts/validation/validate-content.ts",
    "validate:build": "npx tsx scripts/validation/validate-static-urls.ts",
    "validate:url": "npx tsx scripts/validation/validate-live-site.ts",
    "validate": "npx tsx scripts/validation/validate.ts",
    "clean": "rm -rf .astro dist logs",
    "sync": "astro sync",
    "lighthouse": "unlighthouse --site https://sujeet.pro",
    "lighthouse:local": "unlighthouse --site http://localhost:4322",
    "all": "npm run check && npm run lint && npm run format && npm run validate:content && npm run build && npm run validate:build && npm run preview"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@eslint/json": "^0.14.0",
    "@eslint/markdown": "^7.5.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^25.5.0",
    "@unlighthouse/cli": "^0.17.7",
    "eslint": "^9.39.2",
    "eslint-plugin-astro": "^1.6.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "globals": "^17.4.0",
    "playwright": "^1.58.2",
    "prettier": "3.8.1",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "0.7.2",
    "puppeteer": "^24.39.1",
    "remark-code-import": "^1.2.0",
    "remark-inline-svg": "^1.1.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/rss": "^4.0.17",
    "@astrojs/sitemap": "^3.7.1",
    "@docsearch/css": "^4.6.0",
    "@docsearch/js": "^4.6.0",
    "@expressive-code/plugin-collapsible-sections": "^0.41.7",
    "@expressive-code/plugin-line-numbers": "^0.41.7",
    "@iconify-json/carbon": "^1.2.19",
    "@iconify-json/devicon": "^1.2.61",
    "@iconify-json/devicon-plain": "^1.2.56",
    "@types/glob": "^9.0.0",
    "astro": "^5.18.1",
    "astro-expressive-code": "^0.41.7",
    "astro-icon": "^1.1.5",
    "glob": "^13.0.6",
    "json5": "^2.2.3",
    "mdast-util-to-string": "^4.0.0",
    "mermaid-isomorphic": "^3.1.0",
    "reading-time": "^1.5.0",
    "rehype-accessible-emojis": "^0.3.2",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-mathjax": "^7.1.0",
    "remark-emoji": "^5.0.2",
    "remark-math": "^6.0.0",
    "remark-normalize-headings": "^4.0.0",
    "svg-pan-zoom": "^3.6.2",
    "tailwindcss": "^4.2.1"
  },
  "volta": {
    "node": "24.12.0",
    "npm": "11.7.0"
  }
}
